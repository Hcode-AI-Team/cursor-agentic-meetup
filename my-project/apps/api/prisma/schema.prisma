generator client {
  provider = "prisma-client-js"
  output   = "../../../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model access_log {
  id         Int      @id @default(autoincrement())
  user_id    Int?
  ip         String?  @db.VarChar
  user_agent String?
  method     String?  @db.VarChar
  path       String?  @db.VarChar
  mcp_tool   String?  @db.VarChar
  mcp_prompt String?
  created_at DateTime @default(now()) @db.Timestamptz(6)
  user       user?    @relation(fields: [user_id], references: [id], onUpdate: NoAction, map: "user_user_id_fkey")
}

model ai_agent {
  id                Int                               @id @default(autoincrement())
  slug              String                            @unique(map: "ai_agent_slug_unique") @db.VarChar
  provider          ai_agent_provider_7cb93b1143_enum @default(openai)
  model             String?                           @db.VarChar
  instructions      String?
  external_agent_id String?                           @db.VarChar
  created_at        DateTime                          @default(now()) @db.Timestamptz(6)
  updated_at        DateTime                          @default(now()) @db.Timestamptz(6)
  ai_execution      ai_execution[]
}

model ai_execution {
  id                Int                                  @id @default(autoincrement())
  user_id           Int?
  conversation_id   Int?
  agent_id          Int?
  trigger           ai_execution_trigger_c6f1b566d8_enum @default(manual)
  status            ai_execution_status_6ec345f75e_enum  @default(running)
  context_slug      String?                              @db.VarChar
  tokens_input      Int                                  @default(0)
  tokens_output     Int                                  @default(0)
  tokens_total      Int                                  @default(0)
  cost_usd          Decimal                              @default(0) @db.Decimal
  started_at        DateTime                             @db.Timestamptz(6)
  finished_at       DateTime?                            @db.Timestamptz(6)
  error             String?
  created_at        DateTime                             @default(now()) @db.Timestamptz(6)
  updated_at        DateTime                             @default(now()) @db.Timestamptz(6)
  ai_agent          ai_agent?                            @relation(fields: [agent_id], references: [id], onUpdate: NoAction, map: "ai_agent_agent_id_fkey")
  mcp_conversation  mcp_conversation?                    @relation(fields: [conversation_id], references: [id], onUpdate: NoAction, map: "mcp_conversation_conversation_id_fkey")
  user              user?                                @relation(fields: [user_id], references: [id], onUpdate: NoAction, map: "user_user_id_fkey")
  ai_execution_step ai_execution_step[]
}

model ai_execution_step {
  id             Int                                    @id @default(autoincrement())
  execution_id   Int
  step_order     Int                                    @default(0)
  type           ai_execution_step_type_ef4254cada_enum @default(prompt)
  provider       String?                                @db.VarChar
  model          String?                                @db.VarChar
  tool_name      String?                                @db.VarChar
  tokens_input   Int                                    @default(0)
  tokens_output  Int                                    @default(0)
  cost_usd       Decimal                                @default(0) @db.Decimal
  duration_ms    Int                                    @default(0)
  input_summary  String?
  output_summary String?
  success        Boolean                                @default(true)
  error          String?
  created_at     DateTime                               @default(now()) @db.Timestamptz(6)
  ai_execution   ai_execution                           @relation(fields: [execution_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "ai_execution_execution_id_fkey")
}

model ai_instruction {
  id                     Int                                  @id @default(autoincrement())
  slug                   String                               @unique(map: "ai_instruction_slug_unique") @db.VarChar
  layer                  ai_instruction_layer_fde675383a_enum @default(system)
  name                   String                               @db.VarChar
  content                String
  variables_schema       Json?                                @db.Json
  locale                 String                               @default("en") @db.VarChar
  module_slug            String?                              @db.VarChar
  is_active              Boolean                              @default(true)
  version                Int                                  @default(1)
  created_at             DateTime                             @default(now()) @db.Timestamptz(6)
  updated_at             DateTime                             @default(now()) @db.Timestamptz(6)
  ai_instruction_version ai_instruction_version[]
}

model ai_instruction_version {
  id             Int            @id @default(autoincrement())
  instruction_id Int
  version        Int
  content        String
  change_note    String?        @db.VarChar
  created_by_id  Int?
  created_at     DateTime       @default(now()) @db.Timestamptz(6)
  ai_instruction ai_instruction @relation(fields: [instruction_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "ai_instruction_instruction_id_fkey")
  user           user?          @relation(fields: [created_by_id], references: [id], onUpdate: NoAction, map: "user_created_by_id_fkey")
}

model ai_model_pricing {
  id                             Int      @id @default(autoincrement())
  provider                       String   @db.VarChar
  model                          String   @db.VarChar
  price_input_per_million        Decimal  @db.Decimal
  price_output_per_million       Decimal  @db.Decimal
  price_cached_input_per_million Decimal? @db.Decimal
  is_active                      Boolean  @default(true)
  valid_from                     DateTime @db.Timestamptz(6)
  created_at                     DateTime @default(now()) @db.Timestamptz(6)
}

model dashboard {
  id               Int                @id @default(autoincrement())
  slug             String             @unique(map: "dashboard_slug_unique") @db.VarChar
  icon             String?            @db.VarChar
  is_template      Boolean            @default(false)
  created_at       DateTime           @default(now()) @db.Timestamptz(6)
  updated_at       DateTime           @default(now()) @db.Timestamptz(6)
  dashboard_item   dashboard_item[]
  dashboard_locale dashboard_locale[]
  dashboard_role   dashboard_role[]
  dashboard_user   dashboard_user[]
}

model dashboard_component {
  id                         Int                          @id @default(autoincrement())
  slug                       String                       @unique(map: "dashboard_component_slug_unique") @db.VarChar
  library_slug               String                       @default("core") @db.VarChar
  min_width                  Int                          @default(1)
  max_width                  Int?
  min_height                 Int                          @default(1)
  max_height                 Int?
  width                      Int
  height                     Int
  is_resizable               Boolean                      @default(true)
  created_at                 DateTime                     @default(now()) @db.Timestamptz(6)
  updated_at                 DateTime                     @default(now()) @db.Timestamptz(6)
  dashboard_component_locale dashboard_component_locale[]
  dashboard_component_role   dashboard_component_role[]
  dashboard_item             dashboard_item[]
}

model dashboard_component_locale {
  id                     Int                 @id @default(autoincrement())
  locale_id              Int
  dashboard_component_id Int
  name                   String              @db.VarChar(255)
  description            String              @db.VarChar(512)
  created_at             DateTime            @default(now()) @db.Timestamptz(6)
  updated_at             DateTime            @default(now()) @db.Timestamptz(6)
  dashboard_component    dashboard_component @relation(fields: [dashboard_component_id], references: [id], onDelete: Cascade, map: "dashboard_component_dashboard_component_id_fkey")
  locale                 locale              @relation(fields: [locale_id], references: [id], onDelete: Cascade, map: "locale_locale_id_fkey")
}

model dashboard_component_role {
  id                  Int                 @id @default(autoincrement())
  component_id        Int
  role_id             Int
  created_at          DateTime            @default(now()) @db.Timestamptz(6)
  updated_at          DateTime            @default(now()) @db.Timestamptz(6)
  dashboard_component dashboard_component @relation(fields: [component_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "dashboard_component_component_id_fkey")
  role                role                @relation(fields: [role_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "role_role_id_fkey")
}

model dashboard_item {
  id                  Int                 @id @default(autoincrement())
  component_id        Int
  dashboard_id        Int
  width               Int
  height              Int
  x_axis              Int
  y_axis              Int
  created_at          DateTime            @default(now()) @db.Timestamptz(6)
  updated_at          DateTime            @default(now()) @db.Timestamptz(6)
  dashboard_component dashboard_component @relation(fields: [component_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "dashboard_component_component_id_fkey")
  dashboard           dashboard           @relation(fields: [dashboard_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "dashboard_dashboard_id_fkey")
}

model dashboard_locale {
  id           Int       @id @default(autoincrement())
  locale_id    Int
  dashboard_id Int
  name         String    @db.VarChar(255)
  created_at   DateTime  @default(now()) @db.Timestamptz(6)
  updated_at   DateTime  @default(now()) @db.Timestamptz(6)
  dashboard    dashboard @relation(fields: [dashboard_id], references: [id], onDelete: Cascade, map: "dashboard_dashboard_id_fkey")
  locale       locale    @relation(fields: [locale_id], references: [id], onDelete: Cascade, map: "locale_locale_id_fkey")
}

model dashboard_role {
  id           Int       @id @default(autoincrement())
  dashboard_id Int
  role_id      Int
  created_at   DateTime  @default(now()) @db.Timestamptz(6)
  updated_at   DateTime  @default(now()) @db.Timestamptz(6)
  dashboard    dashboard @relation(fields: [dashboard_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "dashboard_dashboard_id_fkey")
  role         role      @relation(fields: [role_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "role_role_id_fkey")
}

model dashboard_user {
  id           Int       @id @default(autoincrement())
  dashboard_id Int
  user_id      Int
  is_home      Boolean   @default(false)
  created_at   DateTime  @default(now()) @db.Timestamptz(6)
  updated_at   DateTime  @default(now()) @db.Timestamptz(6)
  dashboard    dashboard @relation(fields: [dashboard_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "dashboard_dashboard_id_fkey")
  user         user      @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "user_user_id_fkey")
}

model event_webhook {
  id                         Int                                  @id @default(autoincrement())
  slug                       String                               @unique(map: "event_webhook_slug_unique") @db.VarChar
  name                       String                               @db.VarChar
  description                String?
  status                     event_webhook_status_7b7b41a94d_enum @default(active)
  priority                   Int                                  @default(0)
  url                        String
  method                     event_webhook_method_abe30bc650_enum @default(POST)
  headers                    Json?                                @db.Json
  query                      Json?                                @db.Json
  payload                    Json?                                @db.Json
  timeout_ms                 Int                                  @default(10000)
  retry_count                Int                                  @default(0)
  created_at                 DateTime                             @default(now()) @db.Timestamptz(6)
  updated_at                 DateTime                             @default(now()) @db.Timestamptz(6)
  event_webhook_delivery_log event_webhook_delivery_log[]
  event_webhook_event        event_webhook_event[]
}

model event_webhook_delivery_log {
  id                           Int                                               @id @default(autoincrement())
  event_webhook_id             Int?
  integration_event_catalog_id Int?
  outbox_event_id              Int?
  event_name                   String                                            @db.VarChar
  method                       String                                            @db.VarChar
  url                          String
  status                       event_webhook_delivery_log_status_29b023067f_enum
  http_status                  Int?
  duration_ms                  Int                                               @default(0)
  attempt_count                Int                                               @default(1)
  error_message                String?
  request_summary              Json?                                             @db.Json
  response_summary             Json?                                             @db.Json
  created_at                   DateTime                                          @default(now()) @db.Timestamptz(6)
  updated_at                   DateTime                                          @default(now()) @db.Timestamptz(6)
  event_webhook                event_webhook?                                    @relation(fields: [event_webhook_id], references: [id], map: "event_webhook_event_webhook_id_fkey")
  integration_event_catalog    integration_event_catalog?                        @relation(fields: [integration_event_catalog_id], references: [id], map: "integration_event_catalog_integration_event_catalog_id_fkey")
}

model event_webhook_event {
  id                           Int                       @id @default(autoincrement())
  event_webhook_id             Int
  integration_event_catalog_id Int
  created_at                   DateTime                  @default(now()) @db.Timestamptz(6)
  updated_at                   DateTime                  @default(now()) @db.Timestamptz(6)
  event_webhook                event_webhook             @relation(fields: [event_webhook_id], references: [id], onDelete: Cascade, map: "event_webhook_event_webhook_id_fkey")
  integration_event_catalog    integration_event_catalog @relation(fields: [integration_event_catalog_id], references: [id], onDelete: Cascade, map: "integration_event_catalog_integration_event_catalog_id_fkey")
}

model file {
  id            Int           @id @default(autoincrement())
  filename      String        @db.VarChar
  path          String        @db.VarChar
  provider_id   Int
  location      String        @db.VarChar
  mimetype_id   Int
  size          Int           @default(0)
  created_at    DateTime      @default(now()) @db.Timestamptz(6)
  updated_at    DateTime      @default(now()) @db.Timestamptz(6)
  file_mimetype file_mimetype @relation(fields: [mimetype_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "file_mimetype_mimetype_id_fkey")
  file_provider file_provider @relation(fields: [provider_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "file_provider_provider_id_fkey")
  user          user[]
}

model file_mimetype {
  id         Int      @id @default(autoincrement())
  name       String   @db.VarChar
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @db.Timestamptz(6)
  file       file[]
}

model file_provider {
  id                   Int                    @id @default(autoincrement())
  slug                 String                 @unique(map: "file_provider_slug_unique") @db.VarChar
  created_at           DateTime               @default(now()) @db.Timestamptz(6)
  updated_at           DateTime               @default(now()) @db.Timestamptz(6)
  file                 file[]
  file_provider_locale file_provider_locale[]
}

model file_provider_locale {
  id               Int           @id @default(autoincrement())
  locale_id        Int
  file_provider_id Int
  name             String        @db.VarChar(255)
  created_at       DateTime      @default(now()) @db.Timestamptz(6)
  updated_at       DateTime      @default(now()) @db.Timestamptz(6)
  file_provider    file_provider @relation(fields: [file_provider_id], references: [id], onDelete: Cascade, map: "file_provider_file_provider_id_fkey")
  locale           locale        @relation(fields: [locale_id], references: [id], onDelete: Cascade, map: "locale_locale_id_fkey")
}

model inbox_event {
  id              Int                                @id @default(autoincrement())
  outbox_event_id Int
  consumer_name   String                             @db.VarChar
  status          inbox_event_status_97e6c4339b_enum @default(received)
  attempt_count   Int                                @default(0)
  last_error      String?                            @db.VarChar
