  created_at      DateTime                           @default(now()) @db.Timestamptz(6)
  updated_at      DateTime                           @default(now()) @db.Timestamptz(6)
  outbox_event    outbox_event                       @relation(fields: [outbox_event_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "outbox_event_outbox_event_id_fkey")
}

model integration_event_catalog {
  id                         Int                                              @id @default(autoincrement())
  slug                       String                                           @unique(map: "integration_event_catalog_slug_unique") @db.VarChar
  name                       String                                           @db.VarChar
  module                     String                                           @db.VarChar
  aggregate_type             String?                                          @db.VarChar
  description                String?
  payload_schema             Json?                                            @db.Json
  metadata_schema            Json?                                            @db.Json
  status                     integration_event_catalog_status_8c9c7fd473_enum @default(active)
  created_at                 DateTime                                         @default(now()) @db.Timestamptz(6)
  updated_at                 DateTime                                         @default(now()) @db.Timestamptz(6)
  event_webhook_delivery_log event_webhook_delivery_log[]
  event_webhook_event        event_webhook_event[]
}

model integration_link {
  id                 Int      @id @default(autoincrement())
  source_module      String   @db.VarChar
  source_entity_type String   @db.VarChar
  source_entity_id   String   @db.VarChar
  target_module      String   @db.VarChar
  target_entity_type String   @db.VarChar
  target_entity_id   String   @db.VarChar
