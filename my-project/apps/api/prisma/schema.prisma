model mcp_api_key {
  id           Int       @id @default(autoincrement())
  user_id      Int
  name         String    @db.VarChar
  token_hash   String    @db.VarChar
  token_prefix String    @db.VarChar
  type         String    @default("mcp") @db.VarChar
