export type Conversation = {
  id: number;
  title: string | null;
  created_at: string;
  updated_at: string;
};

export type Message = {
  id: number;
  conversation_id: number;
  role: 'user' | 'assistant' | 'tool_call' | 'tool_result';
  content: string;
  tool_name: string | null;
  tool_call_id: string | null;
  created_at: string;
};
