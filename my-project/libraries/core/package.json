{
  "name": "@hed-hog/core",
  "version": "0.0.385",
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "dependencies": {
    "@aws-sdk/client-lambda": "3.1014.0",
    "@aws-sdk/client-s3": "^3.1014.0",
    "@aws-sdk/client-sts": "3.1014.0",
    "@aws-sdk/lib-storage": "3.1014.0",
    "@aws-sdk/s3-request-presigner": "^3.1014.0",
    "@azure/storage-blob": "^12.27.0",
    "@google-cloud/storage": "^7.16.0",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@nestjs/axios": "*",
    "@nestjs/common": "*",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11",
    "@nestjs/event-emitter": "*",
    "@nestjs/jwt": "^11",
    "@nestjs/mapped-types": "*",
    "@nestjs/schedule": "^6.0.1",
    "@nestjs/throttler": "^6.4.0",
    "@simplewebauthn/server": "^13.2.2",
    "argon2": "^0.44.0",
    "axios": "^1.9.0",
    "cookie-parser": "^1.4.7",
    "geoip-lite": "^2.0.2",
    "handlebars": "^4.7.8",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.1",
    "pako": "^2.1.0",
    "pdf-parse": "^1.1.1",
    "playwright": "^1.49.0",
    "png-to-ico": "^2.1.8",
    "qrcode": "^1.5.4",
    "redis": "4.7.1",
    "rxjs": "^7.8.2",
    "sharp": "^0.34.2",
    "speakeasy": "^2.0.0",
    "ua-parser-js": "^2.0.10",
    "uuid": "^11.1.0",
    "@hed-hog/api-prisma": "workspace:*",
    "@hed-hog/api-locale": "workspace:*",
    "@hed-hog/api-types": "workspace:*",
    "@hed-hog/api": "workspace:*",
    "@hed-hog/api-mail": "workspace:*",
    "@hed-hog/api-pagination": "workspace:*"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js",
      "require": "./dist/*.js",
      "default": "./dist/*.js"
    },
    "./package.json": "./package.json"
  },
  "typesVersions": {
    "*": {
      "*": [
        "./dist/*.d.ts",
        "./dist/index.d.ts"
      ]
    }
  },
  "files": [
    "dist",
    "src",
    "hedhog"
  ],
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^4.17.24",
    "@types/geoip-lite": "^1.4.4",
    "@types/multer": "^2.0.0",
    "@types/pako": "^2.0.4",
    "@types/ua-parser-js": "^0.7.39",
    "rimraf": "^6.1.0"
  },
  "scripts": {
    "_dev": "pnpm build --watch",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "test": "jest --config jest.config.ts --runInBand --passWithNoTests",
    "clean": "rimraf dist tsconfig.production.tsbuildinfo",
    "prebuild": "pnpm run clean && pnpm --dir ../.. exec ts-node ./scripts/build-dependencies.ts libraries/core",
    "build": "tsc --project tsconfig.production.json && pnpm run copy:templates && pnpm run copy:language",
    "copy:templates": "node -e \"require('fs').cpSync('src/file/templates', 'dist/file/templates', {recursive: true})\"",
    "copy:language": "node -e \"const fs=require('fs');if(fs.existsSync('src/language'))fs.cpSync('src/language','dist/language',{recursive:true})\"",
    "patch": "pnpm exec ts-node ../../scripts/patch.ts libraries/core",
    "prod": "pnpm run patch && pnpm run build && pnpm publish --access public --no-git-checks"
  }
}