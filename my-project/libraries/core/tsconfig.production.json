{
  "compilerOptions": {
    "experimentalDecorators": true,
    "target": "es2017",
    "module": "commonjs",
    "lib": ["es2021",
      "es2017",
      "es7",
      "es6",
      "DOM",
      "DOM.Iterable"],
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "noImplicitAny": false,
    "strictNullChecks": false,
    "jsx": "react-jsx",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "emitDecoratorMetadata": true,
    "types": ["node"],
    "paths": {
      "@prisma/client": [      
        "../../node_modules/.prisma/client",
        "../../packages/api-prisma/node_modules/.prisma/client"
      ],
      "@prisma/client/*": [
        "../../node_modules/.prisma/client/*",
        "../../packages/api-prisma/node_modules/.prisma/client/*"
      ],
      "@hed-hog/api": ["../../packages/api/dist"],
      "@hed-hog/api/*": ["../../packages/api/dist/*"],
      "@hed-hog/api-locale": ["../../packages/api-locale/dist"],
      "@hed-hog/api-locale/*": ["../../packages/api-locale/dist/*"],
      "@hed-hog/api-mail": ["../../packages/api-mail/dist"],
      "@hed-hog/api-mail/*": ["../../packages/api-mail/dist/*"],
      "@hed-hog/api-pagination": ["../../packages/api-pagination/dist"],
      "@hed-hog/api-pagination/*": ["../../packages/api-pagination/dist/*"],
      "@hed-hog/api-prisma": ["../../packages/api-prisma/dist"],
      "@hed-hog/api-prisma/*": ["../../packages/api-prisma/dist/*"],
      "@hed-hog/api-healthy": ["../../packages/api-healthy/dist"],
      "@hed-hog/api-healthy/*": ["../../packages/api-healthy/dist/*"],

      "@hed-hog/core": ["../../libraries/core/dist"],
      "@hed-hog/core/*": ["../../libraries/core/dist/*"]
    }
  },
  "exclude": ["node_modules", "dist", ".turbo", "hedhog",
    "**/*.spec.ts",
    "**/*.test.ts"]
}
